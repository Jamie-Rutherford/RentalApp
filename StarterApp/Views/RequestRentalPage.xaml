<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StarterApp.ViewModels"
             x:DataType="vm:RequestRentalViewModel"
             x:Class="StarterApp.Views.RequestRentalPage"
             Title="Request Rental">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="{Binding ItemTitle}"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="Select Rental Dates"
                   FontSize="16"
                   TextColor="Gray"
                   HorizontalOptions="Center" />

            <Frame Padding="16" CornerRadius="8">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Start Date" FontAttributes="Bold" />
                    <DatePicker Date="{Binding StartDate}" Format="D" />

                    <Label Text="End Date" FontAttributes="Bold" />
                    <DatePicker Date="{Binding EndDate}" Format="D" />

                </VerticalStackLayout>
            </Frame>

            <Button Text="Request Rental"
                    Command="{Binding SubmitCommand}"
                    IsEnabled="{Binding IsSubmitting, Converter={StaticResource InvertedBoolConverter}}"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50" />

            <Button Text="Cancel"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#512BD4"
                    BorderColor="#512BD4"
                    BorderWidth="1"
                    CornerRadius="8"
                    HeightRequest="50" />

            <ActivityIndicator IsRunning="{Binding IsSubmitting}"
                               IsVisible="{Binding IsSubmitting}"
                               HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
